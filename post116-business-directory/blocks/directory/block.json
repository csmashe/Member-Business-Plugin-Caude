{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "p116/directory",
    "version": "1.0.0",
    "title": "Business Directory",
    "category": "widgets",
    "icon": "building",
    "description": "Display the American Legion Post 116 business directory with search and filtering.",
    "example": {},
    "supports": {
        "html": false,
        "anchor": true
    },
    "attributes": {
        "showFlags": {
            "type": "boolean",
            "default": true
        },
        "perPage": {
            "type": "number",
            "default": 20
        },
        "placeholderText": {
            "type": "string",
            "default": "Search businesses, owners, or services..."
        }
    },
    "textdomain": "post116-business-directory",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./editor.css",
    "style": "file:./style.css",
    "render": "file:./render.php"
}